{
    "name": "qznt",
    "version": "2.0.0",
    "description": "A lightweight typed utility toolkit for modern TypeScript environments.",
    "license": "MIT",
    "author": "xsqu1znt",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "type": "module",
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "check": "tsc --noEmit",
        "format": "prettier --write \"./**/*.{ts,json}\""
    },
    "devDependencies": {
        "@types/node": "^25.9.4",
        "prettier": "^3.9.4",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    }
}
